{
  "RunName": "LongRun",
  "OutputRoot": "artifacts/stress",
  "LogSubdirectory": "logs",
  "Duration": "3.00:00:00",
  "StatusInterval": "00:00:30",
  "ProducerCount": 8,
  "MessagesPerBurst": 100,
  "PausePerBurstMs": 0,
  "MessagePayloadLength": 128,
  "ValidateLineCountAfterRun": true,
  "FailIfDroppedMessages": true,
  "CountOnlyMessagePrefixMatches": true,
  "MessagePrefix": "LONGRUN|",
  "LogOptions": {
    "Name": "LongRun",
    "MinimumLevel": "Information",
    "UseUtcTimestamp": false,
    "IncludeThreadId": true,
    "IncludeLoggerName": true,
    "EnableConsole": false,
    "EnableFile": true,
    "FilePath": "logs",
    "FileConflictMode": "Append",
    "FileRollingMode": "Hourly",
    "MaxFileSizeBytes": 52428800,
    "MaxRollingFiles": 500,
    "QueueCapacity": 8192,
    "BatchSize": 10,
    "FlushIntervalMs": 100,
    "FileBufferSize": 65536,
    "BlockWhenQueueFull": true
  }
}
