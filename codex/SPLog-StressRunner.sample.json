{
  "RunName": "LongRun",
  "OutputRoot": "artifacts/stress",
  "LogSubdirectory": "logs",
  "Duration": "3.00:00:00",
  "StatusInterval": "00:00:30",
  "LoggerScenarios": [
    {
      "ScenarioName": "AppRoot",
      "SharedLoggerKey": "AppRoot",
      "ProducerCount": 2,
      "MessagesPerBurst": 100,
      "PausePerBurstMs": 0,
      "MessagePayloadLength": 128,
      "ValidateLineCountAfterRun": true,
      "FailIfDroppedMessages": true,
      "CountOnlyMessagePrefixMatches": true,
      "MessagePrefix": "LONGRUN|APPROOT|",
      "LogOptions": {
        "Name": "App",
        "MinimumLevel": "Information",
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fffff",
        "UseUtcTimestamp": false,
        "IncludeThreadId": true,
        "IncludeLoggerName": true,
        "IncludeSequenceNumber": true,
        "EnableConsole": false,
        "EnableFile": true,
        "FilePath": "app",
        "FileConflictMode": "Append",
        "FileRollingMode": "Hourly",
        "MaxFileSizeBytes": 10485760,
        "MaxRollingFiles": 100,
        "QueueCapacity": 8192,
        "BatchSize": 10,
        "FlushIntervalMs": 100,
        "FileBufferSize": 65536
      }
    },
